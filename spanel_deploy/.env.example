# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=revma_hire
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string

# SMTP Email Configuration
SMTP_HOST=mail.revma.com.au
SMTP_PORT=465
SMTP_USERNAME=office@revma.com.au
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=office@revma.com.au
NOTIFICATION_EMAIL=peter@revma.com.au

# CORS Configuration (your frontend domain)
CORS_ORIGINS=https://hire.revma.com.au,http://localhost:3000

# Server Configuration
PORT=8001
HOST=0.0.0.0
